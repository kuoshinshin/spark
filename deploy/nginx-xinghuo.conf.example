# 复制到 /etc/nginx/conf.d/spark.conf 后调整 server_name、证书路径与 root
# 前端目录须与 deploy/aliyun-ecs.sh 的 WEB_ROOT 一致（默认 ~/www/xinghuo，即 /home/<用户>/www/xinghuo）

upstream xinghuo_backend {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name your-domain.com;

    # 若已配置 HTTPS，可保留 80 仅做跳转：
    # return 301 https://$host$request_uri;

    root /home/deploy/www/xinghuo;
    index index.html;

    location /api/ {
        proxy_pass http://xinghuo_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 用户上传头像等静态资源（由 Node 提供）
    location /uploads/ {
        proxy_pass http://xinghuo_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    access_log /var/log/nginx/xinghuo.access.log;
    error_log  /var/log/nginx/xinghuo.error.log;
}

