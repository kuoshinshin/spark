# 复制为 .env 后填写真实值，切勿将 .env 提交到仓库。

NODE_ENV=development

PORT=3000
JWT_SECRET=请使用足够长的随机字符串
JWT_EXPIRES_IN=7d

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=xinghuo

# PUBG 官方 API Key（绑定游戏账号、战绩查询必填）
# 在 https://developer.pubg.com 创建应用后获取
# PUBG_API_KEY=你的PUBG_API_Key

# 生产环境：前端域名，多个用英文逗号分隔，例如 https://www.example.com,https://example.com
# CORS_ORIGIN=https://www.example.com

# 反向代理层数（默认 1，与 Nginx 等配合）
# TRUST_PROXY_HOPS=1

# 正式邀请码（注册必填；与启动时 ensureInviteCodes 对齐）。不需要自助注册时设为 0
# INIT_DEFAULT_INVITE_CODE=0
# INIT_DEFAULT_INVITE_CODE=请填写强随机字符串

# 迁移脚本 add_invite_codes_table.js 在生产插入默认码时使用（可选）
# MIGRATION_DEFAULT_INVITE_CODE=

# create_admin_user.js：生产环境必填
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_INITIAL_PASSWORD=请使用强密码

# 豆子局战绩轮询（默认每 10 分钟同步进行中的四排对局）
# BEAN_POLL_ENABLED=true
# BEAN_POLL_INTERVAL_MS=600000
# 同步战绩时允许匹配开局前 N 毫秒内的对局（默认 3 小时）
# BEAN_MATCH_LOOKBACK_MS=10800000

# 测试数据开关：true=启用 mock 数据；false/不设置=生产数据模式（默认）
# MOCK_DATA_ENABLED=false
