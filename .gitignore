# 依赖与构建产物
node_modules/
dist/
*.local

# 环境变量与密钥（切勿提交）
.env
.env.*
!.env.example
xinghuo-backend/.env
xinghuo/.env
xinghuo/.env.*

# 日志与系统文件
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/*
!.vscode/extensions.json

# 临时
*.swp
*.swo

# 本地测试数据 / mock 夹具（默认不提交；仅 *.example.* 模板入库）
**/mock-data/
!**/mock-data.example/**
**/*.fixture.js
!**/*.fixture.example.js
**/fixtures.local.*
**/mock.local.*
